{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yt-dlp-GUI",
  "version": "2.1.0",
  "identifier": "com.ytdlp.gui",
  
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "yt-dlp GUI",
        "width": 860,
        "height": 620,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["resources/backend/yt-dlp-backend"],
    "resources": ["resources/backend/yt-dlp.exe"],
    "publisher": "ZionLux",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Interface gráfica para o yt-dlp",
    "longDescription": "Baixe vídeos e áudios do YouTube e outras plataformas com interface moderna.",
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "minimumWebview2Version": null,
      "nsis": {
  "displayLanguageSelector": false,
  "installerIcon": "icons/icon.ico",
  "installMode": "currentUser",
  "headerImage": "icons/installer-header.bmp",
  "sidebarImage": "icons/installer-sidebar.bmp"
},
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "wix": null
    }
    

  }
}