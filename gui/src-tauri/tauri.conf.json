{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yt-dlp-GUI",
  "version": "2.1.0",
  "identifier": "com.ytdlp.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "yt-dlp GUI",
        "width": 860,
        "height": 620,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}